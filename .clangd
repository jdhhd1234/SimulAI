CompileFlags:
  CompilationDatabase: "build" 
  
  Add: [
    "-std=c++20",
    "--target=x86_64-pc-windows-msvc",
    "-fms-extensions",
    "-fms-compatibility",
    "-fmsc-version=1930",
    "-Wno-unknown-pragmas",
    "-DSOL_EXISTS_OPTIONAL=1"
  ]

Diagnostics:
  UnusedIncludes: Strict
  Suppress: [
    "no_member" # 'no member named ...'
  ]